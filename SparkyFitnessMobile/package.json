{
  "name": "sparkyfitnessmobile",
  "version": "1.4.5",
  "private": true,
  "expo": {
    "autolinking": {
      "exclude": [
        "@expo/dom-webview"
      ]
    }
  },
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint src App.tsx index.js __tests__ --max-warnings 0",
    "lint:compiler": "eslint --no-config-lookup --config eslint.compiler.config.js src App.tsx",
    "start": "expo start",
    "test": "jest",
    "test:run": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run typecheck && pnpm run lint"
  },
  "dependencies": {
    "@assistant-ui/react-ai-sdk": "^1.3.37",
    "@assistant-ui/react-native": "^0.1.27",
    "@bacons/apple-targets": "^4.0.6",
    "@bottom-tabs/react-navigation": "^1.3.1",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@kingstinct/react-native-healthkit": "^13.3.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.4.2",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "^5.90.20",
    "@workspace/shared": "workspace:*",
    "expo": "~56.0.13",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.18",
    "expo-background-task": "~56.0.20",
    "expo-build-properties": "^56.0.20",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.19",
    "expo-dev-client": "^56.0.21",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-health-connect": "^0.1.1",
    "expo-image-picker": "~56.0.19",
    "expo-navigation-bar": "~56.0.3",
    "expo-notifications": "~56.0.19",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.19",
    "expo-splash-screen": "~56.0.11",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.20",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-bottom-tabs": "^1.3.1",
    "react-native-enriched-markdown": "0.6.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-health-connect": "^3.5.3",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-toast-message": "^2.3.3",
    "react-native-ui-datepicker": "^3.1.2",
    "react-native-worklets": "0.8.3",
    "remend": "1.2.2",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.7.0",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.16",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~56.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "expo-atlas": "^0.4.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-expo": "~56.0.5",
    "prettier": "2.8.8",
    "radon-ide": "^0.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "__tests__/hooks/queryTestUtils\\.ts$",
      "__tests__/screens/helpers/"
    ],
    "moduleNameMapper": {
      "^@workspace/shared$": "<rootDir>/../shared/src/index.ts",
      "^@babel/runtime/(.*)$": "<rootDir>/node_modules/@babel/runtime/$1",
      "^remend$": "<rootDir>/node_modules/remend/dist/index.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/[^/]+/node_modules/)?((jest-)?react-native|@react-native(-community)?|expo[^/]*|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@shopify/react-native-skia|react-native-ui-datepicker|@workspace/shared|remend|zod)/)"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.{ts,tsx,js,jsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/metro.config.js",
      "!**/.prettierrc.js",
      "!**/eslint.config.js",
      "!**/expo-env.d.ts",
      "!**/.expo/**",
      "!**/devdocs/**"
    ]
  }
}
