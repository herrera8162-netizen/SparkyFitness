import java.time.format.DateTimeFormatter
import java.util.Locale
import kotlin.math.roundToLong
import org.json.JSONObject

class MacroWidget : GlanceAppWidget() {

    override val stateDefinition = PreferencesGlanceStateDefinition

    override val sizeMode: SizeMode = SizeMode.Responsive(
        setOf(DpSize(200.dp, 200.dp)),
    )

    override suspend fun provideGlance(context: Context, id: GlanceId) {
        val fallbackSnapshot = loadSnapshot(context)
        provideContent {
            GlanceTheme {
                WidgetContent(context = context, fallbackSnapshot = fallbackSnapshot)
            }
        }
    }

    @Composable
    private fun WidgetContent(context: Context, fallbackSnapshot: MacroSnapshot?) {
        val state = currentState<Preferences>()
        val snapshot = parseSnapshot(state[SNAPSHOT_STATE_KEY]) ?: fallbackSnapshot

        val openAppIntent = Intent(Intent.ACTION_VIEW, Uri.parse("sparkyfitnessmobile://"))
            .setPackage(context.packageName)
        val searchIntent = Intent(Intent.ACTION_VIEW, Uri.parse("sparkyfitnessmobile://search"))
            .setPackage(context.packageName)
        val scanIntent = Intent(Intent.ACTION_VIEW, Uri.parse("sparkyfitnessmobile://scan"))
            .setPackage(context.packageName)

        Box(
            modifier = GlanceModifier
                .fillMaxSize()
                .background(GlanceTheme.colors.surface)
                .appWidgetBackgroundCornerRadius()
                .padding(14.dp)
                .clickable(actionStartActivity(openAppIntent)),
            contentAlignment = Alignment.Center,
        ) {
            Column(modifier = GlanceModifier.fillMaxWidth()) {
                CalorieHeader(snapshot = snapshot)
                Spacer(modifier = GlanceModifier.height(10.dp))
                MacroRows(snapshot = snapshot, spacing = 7)
                Spacer(modifier = GlanceModifier.height(14.dp))
                Row(
                    modifier = GlanceModifier.fillMaxWidth(),
                    verticalAlignment = Alignment.CenterVertically,
                ) {
                    ActionButton(
                        intent = searchIntent,
                        icon = R.drawable.ic_widget_search,
                        contentDescription = "Search food",
                        modifier = GlanceModifier
                            .defaultWeight()
                            .height(40.dp),
                    )
                    Box(
                        modifier = GlanceModifier
                            .width(1.dp)
                            .height(48.dp)
                            .background(GlanceTheme.colors.surfaceVariant),
                    ) {}
                    ActionButton(
                        intent = scanIntent,
                        icon = R.drawable.ic_widget_scan,
                        contentDescription = "Scan barcode",
                        modifier = GlanceModifier
                            .defaultWeight()
                            .height(40.dp),
                    )
                }
            }
        }
    }

    @Composable
    private fun CalorieHeader(snapshot: MacroSnapshot?, fontSize: Int = 20) {
        val calories = snapshot?.displayCalories
        val text = if (snapshot?.hasData == true && calories != null) {
            "${formatInt(calories)} kcal left"
        } else {
            "- kcal left"
        }
        Text(
            text = text,
            style = TextStyle(
                color = GlanceTheme.colors.onSurface,
                fontSize = fontSize.sp,
                fontWeight = FontWeight.Bold,
            ),
            maxLines = 1,
            modifier = GlanceModifier.fillMaxWidth(),
        )
    }

    @Composable
    private fun MacroRows(snapshot: MacroSnapshot?, spacing: Int) {
        MacroRow(
            label = "Protein",
            grams = snapshot?.protein ?: 0.0,
            progress = snapshot.progressFor(MacroKind.PROTEIN),
            color = MacroPalette.protein,
        )
        Spacer(modifier = GlanceModifier.height(spacing.dp))
        MacroRow(
            label = "Carbs",
            grams = snapshot?.carbs ?: 0.0,
            progress = snapshot.progressFor(MacroKind.CARBS),
            color = MacroPalette.carbs,
        )
        Spacer(modifier = GlanceModifier.height(spacing.dp))
        MacroRow(
            label = "Fat",
            grams = snapshot?.fat ?: 0.0,
            progress = snapshot.progressFor(MacroKind.FAT),
            color = MacroPalette.fat,
        )
    }

    @Composable
    private fun MacroRow(
        label: String,
        grams: Double,
        progress: Float,
        color: ColorProvider,
    ) {
        Column(modifier = GlanceModifier.fillMaxWidth()) {
            Row(
                modifier = GlanceModifier.fillMaxWidth(),
                verticalAlignment = Alignment.CenterVertically,
            ) {
                Box(
                    modifier = GlanceModifier
                        .size(12.dp)
                        .cornerRadius(6.dp)
                        .background(color),
                ) {}
                Spacer(modifier = GlanceModifier.width(8.dp))
                Text(
                    text = label,
                    style = TextStyle(
                        color = GlanceTheme.colors.onSurfaceVariant,
                        fontSize = 14.sp,
                    ),
                    maxLines = 1,
                )
                Spacer(modifier = GlanceModifier.defaultWeight())
                Text(
                    text = "${formatInt(grams)} g",
                    style = TextStyle(
                        color = GlanceTheme.colors.onSurface,
                        fontSize = 14.sp,
                        fontWeight = FontWeight.Medium,
                    ),
                    maxLines = 1,
                )
            }
            Spacer(modifier = GlanceModifier.height(2.dp))
            LinearProgressIndicator(
                progress = progress,
                modifier = GlanceModifier.fillMaxWidth().height(4.dp),
                color = color,
                backgroundColor = GlanceTheme.colors.surfaceVariant,
            )
        }
    }

    @Composable
    private fun ActionButton(
        intent: Intent,
        icon: Int,
        contentDescription: String,
        modifier: GlanceModifier = GlanceModifier
            .fillMaxWidth()
            .height(42.dp),
    ) {
        Box(
            modifier = modifier.clickable(actionStartActivity(intent)),
            contentAlignment = Alignment.Center,
        ) {
            Image(
                provider = ImageProvider(icon),
                contentDescription = contentDescription,
                colorFilter = ColorFilter.tint(GlanceTheme.colors.primary),
                modifier = GlanceModifier.size(24.dp),
            )
        }
    }

    private data class MacroSnapshot(
        val date: String,
        val protein: Double,
        val carbs: Double,
        val fat: Double,
        val calories: Double,
        val remaining: Double?,
        val lastUpdated: Long,
    ) {
        val proteinKcal: Double = protein * 4.0
        val carbsKcal: Double = carbs * 4.0
        val fatKcal: Double = fat * 9.0
        val macroKcalTotal: Double = proteinKcal + carbsKcal + fatKcal
        val displayCalories: Double? = remaining ?: calories
        val hasData: Boolean =
            macroKcalTotal > 0.0 || (displayCalories ?: 0.0) > 0.0
    }

    private enum class MacroKind {
        PROTEIN,
        CARBS,
        FAT,
    }

    private fun loadSnapshot(context: Context): MacroSnapshot? {
        val prefs = context.getSharedPreferences(
            MacroWidgetReceiver.PREFS_NAME,
            Context.MODE_PRIVATE,
        )
        return parseSnapshot(prefs.getString(MacroWidgetReceiver.PREFS_KEY_SNAPSHOT, null))
    }

    private fun parseSnapshot(json: String?): MacroSnapshot? {
        if (json == null) return null
        return try {
            val obj = JSONObject(json)
            val date = obj.optString("date", "")
            if (!isToday(date)) return null
            MacroSnapshot(
                date = date,
                protein = obj.safeDouble("protein"),
                carbs = obj.safeDouble("carbs"),
                fat = obj.safeDouble("fat"),
                calories = obj.safeDouble("calories"),
                remaining = if (obj.has("remaining")) {
                    obj.safeDouble("remaining")
                } else {
                    null
                },
                lastUpdated = obj.optLong("lastUpdated", 0L),
            )
        } catch (e: Exception) {
            null
        }
    }

    private fun MacroSnapshot?.progressFor(kind: MacroKind): Float {
        val snapshot = this ?: return 0f
        val total = snapshot.macroKcalTotal
        if (total <= 0.0) return 0f

        val value = when (kind) {
            MacroKind.PROTEIN -> snapshot.proteinKcal
            MacroKind.CARBS -> snapshot.carbsKcal
            MacroKind.FAT -> snapshot.fatKcal
        }
        return (value / total).coerceIn(0.0, 1.0).toFloat()
    }

    private fun JSONObject.safeDouble(name: String): Double {
        val value = optDouble(name, 0.0)
        return if (value.isFinite()) value else 0.0
    }

    private fun isToday(date: String): Boolean {
        if (date.isBlank()) return false
        return try {
            val parsed = LocalDate.parse(date, DateTimeFormatter.ISO_LOCAL_DATE)
            parsed == LocalDate.now()
        } catch (e: Exception) {
            false
        }
    }

    private fun formatInt(value: Double): String {
        return String.format(Locale.getDefault(), "%,d", value.roundToLong())
    }

    companion object {
        val SNAPSHOT_STATE_KEY = stringPreferencesKey(MacroWidgetReceiver.PREFS_KEY_SNAPSHOT)
    }
}

private object MacroPalette {
    val protein = ColorProvider(Color(0xFFF6B151))
    val carbs = ColorProvider(Color(0xFF7BD680))
    val fat = ColorProvider(Color(0xFF6DCBE9))
}
